Date: Fri, 9 May 2025 04:16:46 +0800
Subject: [PATCH] power: smb5-lib: Implement bypass charging
 [diphons]: Adapted to Xiaomi Kona
 Authored-by: Rve27 <rve27github@gmail.com>
 Signed-off-by: Rudi Setiyawan <diphons@gmail.com>

---
 drivers/power/supply/qcom/smb5-lib-munch.c  | 43 +++++++++++++++++---
 drivers/power/supply/qcom/smb5-lib-munch.h  |  1 +
 drivers/power/supply/qcom/smb5-lib-psyche.c | 44 ++++++++++++++++++---
 drivers/power/supply/qcom/smb5-lib.c        | 43 +++++++++++++++++---
 drivers/power/supply/qcom/smb5-lib.h        |  1 +
 drivers/power/supply/qcom_cas/smb5-lib.c    | 40 +++++++++++++++++--
 drivers/power/supply/qcom_cas/smb5-lib.h    |  1 +
 7 files changed, 155 insertions(+), 18 deletions(-)

diff --git a/drivers/power/supply/qcom/smb5-lib-munch.c b/drivers/power/supply/qcom/smb5-lib-munch.c
index f8cc0c806..4e7f41596 100755
--- a/drivers/power/supply/qcom/smb5-lib-munch.c
+++ b/drivers/power/supply/qcom/smb5-lib-munch.c
@@ -45,6 +45,7 @@
 
 bool off_charge_flag;
 static bool first_boot_flag;
+static int bypass_charging = 0;
 
 static void update_sw_icl_max(struct smb_charger *chg, int pst);
 static int smblib_get_prop_typec_mode(struct smb_charger *chg);
@@ -2401,9 +2402,13 @@ int smblib_vbus_regulator_is_enabled(struct regulator_dev *rdev)
 int smblib_get_prop_input_suspend(struct smb_charger *chg,
 				  union power_supply_propval *val)
 {
-	val->intval
-		= (get_client_vote(chg->usb_icl_votable, USER_VOTER) == 0)
-		 || get_client_vote(chg->dc_suspend_votable, USER_VOTER);
+	if ((get_client_vote(chg->chg_disable_votable, BYPASS_VOTER) == 1)) {
+		val->intval = 1;
+	} else if (bypass_charging) {
+		val->intval = 2;
+	} else {
+		val->intval = 0;
+	}
 	return 0;
 }
 
@@ -3169,20 +3174,37 @@ int smblib_set_prop_input_suspend(struct smb_charger *chg,
 	int rc;
 
 	/* vote 0mA when suspended */
-	rc = vote(chg->usb_icl_votable, USER_VOTER, (bool)val->intval, 0);
+	rc = vote(chg->usb_icl_votable, USER_VOTER, false, 0);
 	if (rc < 0) {
 		smblib_err(chg, "Couldn't vote to %s USB rc=%d\n",
 			(bool)val->intval ? "suspend" : "resume", rc);
 		return rc;
 	}
 
-	rc = vote(chg->dc_suspend_votable, USER_VOTER, (bool)val->intval, 0);
+	rc = vote(chg->dc_suspend_votable, USER_VOTER, false, 0);
 	if (rc < 0) {
 		smblib_err(chg, "Couldn't vote to %s DC rc=%d\n",
 			(bool)val->intval ? "suspend" : "resume", rc);
 		return rc;
 	}
 
+	if (val->intval == 1) {
+          	rc = vote(chg->chg_disable_votable, BYPASS_VOTER, 1, 0);
+          	bypass_charging = 0;
+      	} else if (val->intval == 2) {
+          	rc = vote(chg->chg_disable_votable, BYPASS_VOTER, 0, 0);
+          	bypass_charging = 1;
+      	} else {
+          	rc = vote(chg->chg_disable_votable, BYPASS_VOTER, 0, 0);
+          	bypass_charging = 0;
+      	}
+
+ 	if (rc < 0) {
+  		smblib_err(chg, "Couldn't vote to %d input_suspend rc=%d\n",
+  			val->intval, rc);
+  		return rc;
+  	}
+
 	power_supply_changed(chg->batt_psy);
 	return rc;
 }
@@ -3490,6 +3512,11 @@ static int smblib_therm_charging(struct smb_charger *chg)
 	int thermal_fcc_ua = 0;
 	int rc;
 
+#ifdef CONFIG_D8G_SERVICE
+	if (skip_thermal || bypass_charging)
+		chg->system_temp_level = 0;
+#endif
+
 	if (chg->system_temp_level >= MAX_TEMP_LEVEL)
 		return 0;
 
@@ -3579,6 +3606,9 @@ static void smblib_thermal_setting_work(struct work_struct *work)
 	struct smb_charger *chg = container_of(work, struct smb_charger,
 			thermal_setting_work.work);
 
+	if (bypass_charging)
+		chg->pps_thermal_level = 0;
+
 	if (chg->pps_thermal_level > chg->system_temp_level) {
 		if (chg->pps_thermal_level - chg->system_temp_level >= 2)
 			chg->pps_thermal_level -= 2;
@@ -3638,6 +3668,9 @@ int smblib_set_prop_system_temp_level(struct smb_charger *chg,
 	vote(chg->chg_disable_votable, THERMAL_DAEMON_VOTER, false, 0);
 #endif
 
+	if (bypass_charging)
+		chg->system_temp_level = 0;
+
 	if (chg->pd_active == POWER_SUPPLY_PD_PPS_ACTIVE)
 		schedule_delayed_work(&chg->thermal_setting_work, 3 * HZ);
 	else
