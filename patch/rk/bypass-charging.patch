 <197677662+Norikimika@users.noreply.github.com>
Date: Fri, 9 May 2025 04:41:13 +0800
Subject: [PATCH] power: smb5-lib: Implement bypass charging
 [diphons]: Adapted to Xiaomi Kona
 Authored-by: Rve27 <rve27github@gmail.com>
 Signed-off-by: Rudi Setiyawan <diphons@gmail.com>

---
 drivers/power/supply/cas_qcom/smb5-lib.c    | 40 ++++++++++++++++--
 drivers/power/supply/cas_qcom/smb5-lib.h    |  2 +-
 drivers/power/supply/qcom/smb5-lib-munch.c  | 44 +++++++++++++++++---
 drivers/power/supply/qcom/smb5-lib-munch.h  |  1 +
 drivers/power/supply/qcom/smb5-lib-psyche.c | 45 ++++++++++++++++++---
 drivers/power/supply/qcom/smb5-lib.c        | 44 +++++++++++++++++---
 drivers/power/supply/qcom/smb5-lib.h        |  1 +
 7 files changed, 158 insertions(+), 19 deletions(-)

diff --git a/drivers/power/supply/cas_qcom/smb5-lib.c b/drivers/power/supply/cas_qcom/smb5-lib.c
index a17bf6ca8..79db69923 100644
--- a/drivers/power/supply/cas_qcom/smb5-lib.c
+++ b/drivers/power/supply/cas_qcom/smb5-lib.c
@@ -42,6 +42,7 @@
 	&& (!chg->typec_legacy || chg->typec_legacy_use_rp_icl))
 
 static bool off_charge_flag;
+static int bypass_charging = 0;
 
 static void update_sw_icl_max(struct smb_charger *chg, int pst);
 static int smblib_get_prop_typec_mode(struct smb_charger *chg);
@@ -2542,7 +2543,13 @@ int smblib_vbus_regulator_is_enabled(struct regulator_dev *rdev)
 int smblib_get_prop_input_suspend(struct smb_charger *chg,
 				  union power_supply_propval *val)
 {
-	val->intval = get_effective_result(chg->input_suspend_votable);
+	if ((get_client_vote(chg->chg_disable_votable, BYPASS_VOTER) == 1)) {
+		val->intval = 1;
+	} else if (bypass_charging) {
+		val->intval = 2;
+	} else {
+		val->intval = 0;
+	}
 
 	return 0;
 }
@@ -3295,9 +3302,26 @@ static void smblib_get_start_vbat_before_step_charge(struct smb_charger *chg)
 int smblib_set_prop_input_suspend(struct smb_charger *chg,
 				  const union power_supply_propval *val)
 {
-	int rc;
+	int rc = 0;
+
+	vote(chg->input_suspend_votable, USER_VOTER, false, 0);
+
+	if (val->intval == 1) {
+		rc = vote(chg->chg_disable_votable, BYPASS_VOTER, 1, 0);
+		bypass_charging = 0;
+	} else if (val->intval == 2) {
+		rc = vote(chg->chg_disable_votable, BYPASS_VOTER, 0, 0);
+		bypass_charging = 1;
+	} else {
+		rc = vote(chg->chg_disable_votable, BYPASS_VOTER, 0, 0);
+		bypass_charging = 0;
+	}
 
-	vote(chg->input_suspend_votable, USER_VOTER, val->intval ? true : false, 0);
+ 	if (rc < 0) {
+  		pr_err(chg, "Couldn't vote to %d input_suspend rc=%d\n",
+  			val->intval, rc);
+  		return rc;
+  	}
 
 	power_supply_changed(chg->batt_psy);
 
@@ -3602,6 +3626,13 @@ static int smblib_therm_charging(struct smb_charger *chg)
 	if (chg->system_temp_level >= MAX_TEMP_LEVEL)
 		return 0;
 
+#ifdef CONFIG_D8G_SERVICE
+	if (skip_thermal || bypass_charging) {
+		temp_level = chg->system_temp_level;
+		chg->system_temp_level = 0;
+	}
+#endif
+
 	switch (chg->real_charger_type) {
 	case POWER_SUPPLY_TYPE_USB_HVDCP:
 		thermal_icl_ua = chg->thermal_mitigation_qc2[chg->system_temp_level];
@@ -3793,6 +3824,9 @@ int smblib_set_prop_system_temp_level(struct smb_charger *chg,
 	vote(chg->chg_disable_votable, THERMAL_DAEMON_VOTER, false, 0);
 #endif
 
+	if (bypass_charging)
+		chg->system_temp_level = 0;
+
 	if (chg->thermal_taper && chg->pd_active == POWER_SUPPLY_PD_PPS_ACTIVE) {
 		schedule_delayed_work(&chg->thermal_setting_work,
 				msecs_to_jiffies(chg->thermal_taper_rate));
diff --git a/drivers/power/supply/cas_qcom/smb5-lib.h b/drivers/power/supply/cas_qcom/smb5-lib.h
index 2bcb953e0..5f8df4d54 100644
--- a/drivers/power/supply/cas_qcom/smb5-lib.h
+++ b/drivers/power/supply/cas_qcom/smb5-lib.h
@@ -112,7 +112,7 @@ enum print_reason {
 #define TAPER_VOTER			"TAPER_VOTER"
 #define CP_VOTER			"CP_VOTER"
 #define BMS_FC_VOTER			"BMS_FC_VOTER"
-
+#define BYPASS_VOTER			"BYPASS_VOTER"
 
 /* thermal micros */
 #define MAX_TEMP_LEVEL		16
diff --git a/drivers/power/supply/qcom/smb5-lib-munch.c b/drivers/power/supply/qcom/smb5-lib-munch.c
index dee8fc0eb..185ac8321 100755
